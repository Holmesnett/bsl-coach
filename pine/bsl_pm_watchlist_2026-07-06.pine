//@version=5
// BSL PM Watchlist — 2026-07-06 (from Adam's PM Planning sheet + call)
// Colors per Dave's scheme: purple = entry KL, green = targets,
// red = supports / downside targets, yellow dotted = session High/Low,
// white dotted = current price.
// Alert fires on a 5-min CLOSE through an entry KL (Adam's trigger).
// Paste over the saved "BSL PM Watchlist" TV script, then "Apply to all
// charts in layout". One alert per chart: "Any alert() function call".
//
// NOTE 7/6: QQQ and MU are PM-BSLs — per 7/2 decision the premarket-BSL
// variant is PAPER-TRACK ONLY until specced. Alerts still fire for tracking.
indicator("BSL PM Watchlist", overlay = true, max_lines_count = 100, max_labels_count = 100)

// ---------- inputs ----------
showTargets  = input.bool(true,  "Show targets")
showSupports = input.bool(true,  "Show supports / downside targets")
showHL       = input.bool(true,  "Show session High/Low (yellow dotted)")
showPrice    = input.bool(true,  "Show current price line (white dotted)")
showLabels   = input.bool(true,  "Show level labels")

colEntry = input.color(color.new(color.purple, 0), "Entry KL")
colTP    = input.color(color.new(color.green, 0),  "Target")
colDn    = input.color(color.new(color.red, 0),    "Support / downside")
colHL    = input.color(color.new(color.yellow, 0), "High/Low")
colPx    = input.color(color.new(color.white, 0),  "Current price")

// ---------- per-symbol levels ----------
var float[] eL = array.new_float() // long entry KLs (purple, solid)
var float[] eS = array.new_float() // short entry KLs (purple, dashed)
var float[] tp = array.new_float() // targets (green)
var float[] dn = array.new_float() // supports / downside targets (red)

if barstate.isfirst
    string t = syminfo.ticker
    if t == "QQQ"
        // PM-BSL (paper-track). Bear case from the call: short 720 -> 717 -> 714.70 -> 710.
        array.push(eL, 722.10)
        array.push(eS, 720.00)
        array.push(tp, 725.60),  array.push(tp, 729.60)
        array.push(dn, 717.00),  array.push(dn, 714.70),  array.push(dn, 710.00)
    if t == "MU"
        // PM-BSL (paper-track). Gap levels (purple on Adam's chart): 1012.60 entry, 1051.50 gap fill.
        array.push(eL, 1012.60)
        array.push(tp, 1051.50)
        array.push(dn, 1000.00)
    if t == "AAPL"
        // Multi-Day BSL — Broadcom chip deal. 317.40 = 52-week high.
        array.push(eL, 308.26)
        array.push(tp, 313.40),  array.push(tp, 317.40)
        array.push(dn, 307.00)
    if t == "AVGO"
        // Daily-BSL — Apple partnership. Call: may take the pullback-to-374 entry.
        array.push(eL, 374.00)
        array.push(tp, 380.00),  array.push(tp, 386.22)
        array.push(dn, 370.00)
    if t == "WULF"
        // Daily-BSL — $19B/20-yr Anthropic lease. "All the stars aligned."
        array.push(eL, 24.90)
        array.push(tp, 26.75),   array.push(tp, 27.90)
        array.push(dn, 24.00)
    if t == "GLW"
        // Multi-Day BSL — BofA PT upgrade to $243.
        array.push(eL, 202.00)
        array.push(tp, 208.20),  array.push(tp, 212.75)
        array.push(dn, 200.00)
    if t == "INTC"
        // Multi-Day BSL — chip-sector recovery (Adam: "weaker headline").
        array.push(eL, 125.00)
        array.push(tp, 126.65),  array.push(tp, 130.70)
        array.push(dn, 124.00)
    if t == "SPCX"
        // Multi-Day BSL — joins Nasdaq-100 tomorrow (7/7).
        array.push(eL, 166.00)
        array.push(tp, 171.77),  array.push(tp, 176.50)
        array.push(dn, 164.00)

// ---------- draw level lines (once, on the LAST bar) ----------
// Anchoring at bar 0 fails on deep-history symbols (TV won't draw objects
// >10,000 bars back — QQQ's 5-min history trips this and the pane goes
// blank). Anchor at the current bar with extend.both instead.
drawLevel(float y, color c, string style, int width) =>
    line.new(bar_index - 1, y, bar_index, y, extend = extend.both, color = c, style = style, width = width)

var label[] lbls = array.new_label()
mkLabel(float y, color c, string txt) =>
    label.new(bar_index, y, txt, style = label.style_label_left, color = color.new(color.black, 100), textcolor = c, size = size.small)

var bool levelsDrawn = false
if barstate.islast and not levelsDrawn
    levelsDrawn := true
    if array.size(eL) > 0
        for i = 0 to array.size(eL) - 1
            y = array.get(eL, i)
            drawLevel(y, colEntry, line.style_solid, 2)
            if showLabels
                array.push(lbls, mkLabel(y, colEntry, "ENTRY " + str.tostring(y)))
    if array.size(eS) > 0
        for i = 0 to array.size(eS) - 1
            y = array.get(eS, i)
            drawLevel(y, colEntry, line.style_dashed, 2)
            if showLabels
                array.push(lbls, mkLabel(y, colEntry, "ENTRY (short) " + str.tostring(y)))
    if showTargets and array.size(tp) > 0
        for i = 0 to array.size(tp) - 1
            y = array.get(tp, i)
            drawLevel(y, colTP, line.style_solid, 1)
            if showLabels
                array.push(lbls, mkLabel(y, colTP, "T" + str.tostring(i + 1) + " " + str.tostring(y)))
    if showSupports and array.size(dn) > 0
        for i = 0 to array.size(dn) - 1
            y = array.get(dn, i)
            drawLevel(y, colDn, line.style_solid, 1)
            if showLabels
                array.push(lbls, mkLabel(y, colDn, "S " + str.tostring(y)))

// keep labels pinned to the right edge
if barstate.islast and showLabels and array.size(lbls) > 0
    for i = 0 to array.size(lbls) - 1
        label.set_x(array.get(lbls, i), bar_index + 3)

// self-diagnosis: if the script is running but this symbol has no levels,
// say so — a blank pane then means "indicator not added", never a mystery.
var label noLvl = na
if barstate.islast and array.size(eL) == 0 and array.size(eS) == 0
    if na(noLvl)
        noLvl := label.new(bar_index, close, "BSL: no levels for " + syminfo.ticker + " on today's sheet", style = label.style_label_left, color = color.new(color.gray, 70), textcolor = color.silver, size = size.small)
    label.set_x(noLvl, bar_index + 3), label.set_y(noLvl, close)

// ---------- session high/low (yellow dotted) ----------
newDay = dayofmonth != dayofmonth[1]
var float dayHi = na
var float dayLo = na
dayHi := newDay ? high : math.max(nz(dayHi, high), high)
dayLo := newDay ? low  : math.min(nz(dayLo, low), low)

var line hiLine = na
var line loLine = na
var line pxLine = na
if barstate.islast
    if showHL
        if na(hiLine)
            hiLine := line.new(bar_index - 1, dayHi, bar_index, dayHi, extend = extend.both, color = colHL, style = line.style_dotted, width = 1)
            loLine := line.new(bar_index - 1, dayLo, bar_index, dayLo, extend = extend.both, color = colHL, style = line.style_dotted, width = 1)
        line.set_y1(hiLine, dayHi), line.set_y2(hiLine, dayHi)
        line.set_y1(loLine, dayLo), line.set_y2(loLine, dayLo)
    if showPrice
        if na(pxLine)
            pxLine := line.new(bar_index - 1, close, bar_index, close, extend = extend.both, color = colPx, style = line.style_dotted, width = 1)
        line.set_y1(pxLine, close), line.set_y2(pxLine, close)

// ---------- entry alerts: 5-min CLOSE through the KL ----------
if barstate.isconfirmed
    if array.size(eL) > 0
        for i = 0 to array.size(eL) - 1
            lvl = array.get(eL, i)
            if close[1] < lvl and close >= lvl
                alert(syminfo.ticker + ": 5-min close ABOVE entry KL " + str.tostring(lvl) + " (close " + str.tostring(close) + ")", alert.freq_once_per_bar)
    if array.size(eS) > 0
        for i = 0 to array.size(eS) - 1
            lvl = array.get(eS, i)
            if close[1] > lvl and close <= lvl
                alert(syminfo.ticker + ": 5-min close BELOW short entry KL " + str.tostring(lvl) + " (close " + str.tostring(close) + ")", alert.freq_once_per_bar)
